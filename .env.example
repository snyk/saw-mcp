# Snyk API & Web API key (required)
# Get yours at https://plus.probely.app/api-keys (Snyk API & Web console)
# Create with custom role, limited-scope API key
MCP_SAW_API_KEY=

# Base URL override (optional, defaults to https://api.probely.com)
# MCP_SAW_BASE_URL=https://api.probely.com

# Config file path (optional; overrides default config/config.yaml lookup)
# MCP_SAW_CONFIG_PATH=/path/to/config.yaml

# Log level (optional; default: INFO)
# MCP_SAW_LOG_LEVEL=INFO

# SSRF allow-list (optional). Comma-separated hostnames permitted when fetching
# Postman/OpenAPI schema URLs for API targets. Matching covers the exact host
# and its subdomains. When unset, any public HTTPS host is allowed (private,
# loopback, and link-local addresses are always blocked).
# MCP_SAW_URL_ALLOWLIST=raw.githubusercontent.com,api.example.com

# Audit log file (optional). When set, one structured line per MCP tool call
# (tool, timestamp, outcome, duration) is appended here for a persistent,
# SIEM-ingestible trail. When unset, audit lines still go to the standard log.
# MCP_SAW_AUDIT_LOG=/var/log/saw-mcp-audit.log
