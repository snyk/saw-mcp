# Snyk API & Web API key (required)
# Get yours at https://plus.probely.app/api-keys (Snyk API & Web console)
# Create with custom role, limited-scope API key
MCP_SAW_API_KEY=

# Base URL override (optional, defaults to https://api.probely.com)
# MCP_SAW_BASE_URL=https://api.probely.com

# Config file path (optional; overrides default config/config.yaml lookup)
# MCP_SAW_CONFIG_PATH=/path/to/config.yaml

# Log level (optional; default: INFO)
# MCP_SAW_LOG_LEVEL=INFO
